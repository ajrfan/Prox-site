<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Prox</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --g0: #0a1a0e;
    --g1: #0f2614;
    --g2: #163320;
    --g3: #1e4a2d;
    --g4: #276038;
    --g5: #2e7342;
    --g6: #38914f;
    --g7: #4aaa63;
    --g8: #6dc882;
    --g9: #9adba0;
    --ga: #c2edc6;
    --gb: #e4f7e6;
    --card: rgba(255,255,255,0.07);
    --card-border: rgba(109,200,130,0.18);
    --card-hover: rgba(255,255,255,0.12);
    --text: #e4f7e6;
    --text-muted: #9adba0;
    --text-dim: #4aaa63;
    --radius: 20px;
    --radius-sm: 12px;
    --radius-lg: 28px;
    --radius-pill: 999px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--g0);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Ambient bg blobs */
  body::before {
    content: '';
    position: fixed;
    top: -200px; left: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(46,115,66,0.35) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  body::after {
    content: '';
    position: fixed;
    bottom: -150px; right: -150px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(56,145,79,0.25) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .page { position: relative; z-index: 1; max-width: 780px; margin: 0 auto; padding: 0 20px 60px; }

  /* ── Header ── */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 0 24px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    width: 42px; height: 42px;
    background: linear-gradient(135deg, var(--g5), var(--g7));
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    box-shadow: 0 4px 18px rgba(74,170,99,0.35);
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 4px 18px rgba(74,170,99,0.35); }
    50% { box-shadow: 0 4px 28px rgba(74,170,99,0.6); }
  }

  .logo-text {
    font-size: 26px;
    font-weight: 900;
    letter-spacing: -0.5px;
    color: var(--text);
  }

  .logo-text span {
    color: var(--g8);
  }

  .header-badges {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .badge {
    padding: 5px 13px;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.3px;
  }

  .badge-online {
    background: rgba(74,170,99,0.2);
    color: var(--g8);
    border: 1px solid rgba(74,170,99,0.35);
    display: flex; align-items: center; gap: 5px;
  }

  .badge-online::before {
    content: '';
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--g7);
    animation: blink 2s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .badge-version {
    background: rgba(255,255,255,0.07);
    color: var(--text-muted);
    border: 1px solid rgba(255,255,255,0.1);
  }

  /* ── Search bar ── */
  .search-wrap {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    padding: 6px 6px 6px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
    transition: border-color 0.2s, background 0.2s;
    backdrop-filter: blur(10px);
  }

  .search-wrap:focus-within {
    border-color: rgba(109,200,130,0.5);
    background: rgba(255,255,255,0.1);
  }

  .search-icon {
    font-size: 18px;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    font-family: 'Nunito', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    caret-color: var(--g7);
  }

  .search-input::placeholder { color: var(--text-dim); font-weight: 500; }

  .search-btn {
    background: linear-gradient(135deg, var(--g5), var(--g7));
    color: #0a1a0e;
    border: none;
    border-radius: 18px;
    padding: 11px 22px;
    font-family: 'Nunito', sans-serif;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    letter-spacing: 0.2px;
  }

  .search-btn:hover {
    transform: scale(1.03);
    box-shadow: 0 4px 16px rgba(74,170,99,0.4);
  }

  .search-btn:active { transform: scale(0.98); }

  /* ── Quick links ── */
  .quick-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 12px;
  }

  .quick-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .quick-link {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-pill);
    padding: 7px 16px;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-muted);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.18s;
    backdrop-filter: blur(8px);
  }

  .quick-link:hover {
    background: rgba(74,170,99,0.15);
    border-color: rgba(74,170,99,0.4);
    color: var(--g8);
    transform: translateY(-1px);
  }

  /* ── Section title ── */
  .section-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 14px;
    margin-top: 32px;
  }

  /* ── App grid ── */
  .app-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 8px;
  }

  .app-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 20px 16px 16px;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    transition: all 0.2s;
    backdrop-filter: blur(8px);
    position: relative;
    overflow: hidden;
  }

  .app-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(109,200,130,0.4), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .app-card:hover {
    background: var(--card-hover);
    border-color: rgba(109,200,130,0.35);
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .app-card:hover::before { opacity: 1; }

  .app-icon {
    width: 52px; height: 52px;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
  }

  .app-name {
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }

  .app-tag {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--text-dim);
    text-transform: uppercase;
  }

  /* Icon color variants */
  .ic-green { background: rgba(46,115,66,0.4); }
  .ic-lime { background: rgba(74,170,99,0.3); }
  .ic-dark { background: rgba(255,255,255,0.07); }
  .ic-teal { background: rgba(29,158,117,0.3); }
  .ic-warn { background: rgba(186,117,23,0.3); }

  /* ── Proxy frame card ── */
  .proxy-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    backdrop-filter: blur(10px);
    margin-bottom: 28px;
  }

  .proxy-tabbar {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    padding: 10px 14px 0;
    border-bottom: 1px solid rgba(109,200,130,0.15);
    background: rgba(0,0,0,0.2);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .proxy-tabbar::-webkit-scrollbar { display: none; }

  .proxy-tab {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 7px 14px 8px;
    border-radius: 10px 10px 0 0;
    font-family: 'Nunito', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: var(--text-dim);
    cursor: pointer;
    border: 1px solid transparent;
    border-bottom: none;
    background: transparent;
    transition: all 0.15s;
    white-space: nowrap;
    position: relative;
    bottom: -1px;
    user-select: none;
  }

  .proxy-tab:hover:not(.proxy-tab-active) {
    background: rgba(255,255,255,0.05);
    color: var(--text-muted);
  }

  .proxy-tab-active {
    background: var(--card);
    border-color: rgba(109,200,130,0.2);
    border-bottom-color: transparent;
    color: var(--g8);
  }

  .proxy-tab-favicon { font-size: 13px; line-height: 1; }

  .proxy-tab-close {
    width: 14px; height: 14px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px;
    color: var(--text-dim);
    transition: background 0.12s, color 0.12s;
    margin-left: 2px;
  }
  .proxy-tab-close:hover { background: rgba(255,80,80,0.25); color: #ff8080; }

  .proxy-tab-new {
    width: 26px; height: 26px;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
    color: var(--text-dim);
    cursor: pointer;
    margin-bottom: 1px;
    transition: background 0.12s, color 0.12s;
    flex-shrink: 0;
  }
  .proxy-tab-new:hover { background: rgba(74,170,99,0.15); color: var(--g7); }

  .proxy-urlbar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgba(0,0,0,0.12);
    border-bottom: 1px solid rgba(109,200,130,0.1);
  }

  .proxy-nav-btn {
    width: 26px; height: 26px;
    border-radius: 7px;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(109,200,130,0.12);
    color: var(--text-dim);
    font-size: 13px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: all 0.12s;
    font-family: 'Nunito', sans-serif;
    font-weight: 800;
  }
  .proxy-nav-btn:hover { background: rgba(74,170,99,0.15); color: var(--g8); border-color: rgba(109,200,130,0.3); }

  .proxy-url-bar {
    flex: 1;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(109,200,130,0.15);
    border-radius: 8px;
    padding: 5px 12px;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--g9);
    letter-spacing: -0.2px;
  }

  .proxy-content {
    padding: 28px 24px;
    text-align: center;
  }

  .proxy-big-icon {
    font-size: 48px;
    margin-bottom: 12px;
    display: block;
  }

  .proxy-title {
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 6px;
  }

  .proxy-sub {
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 20px;
    font-weight: 500;
  }

  .proxy-input-row {
    display: flex;
    gap: 10px;
    max-width: 480px;
    margin: 0 auto;
  }

  .proxy-input {
    flex: 1;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(109,200,130,0.2);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    font-family: 'Nunito', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }

  .proxy-input:focus { border-color: rgba(109,200,130,0.5); }
  .proxy-input::placeholder { color: var(--text-dim); font-weight: 500; }

  .proxy-go {
    background: linear-gradient(135deg, var(--g4), var(--g6));
    color: #c2edc6;
    border: none;
    border-radius: var(--radius-sm);
    padding: 12px 22px;
    font-family: 'Nunito', sans-serif;
    font-size: 14px;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .proxy-go:hover {
    transform: scale(1.04);
    box-shadow: 0 4px 18px rgba(46,115,66,0.5);
  }

  /* ── Stats row ── */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 28px;
  }

  .stat-card {
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius);
    padding: 18px 16px;
    backdrop-filter: blur(8px);
    transition: all 0.2s;
  }

  .stat-card:hover {
    background: var(--card-hover);
    transform: translateY(-2px);
  }

  .stat-num {
    font-size: 26px;
    font-weight: 900;
    color: var(--g8);
    line-height: 1;
    font-family: 'Space Mono', monospace;
  }

  .stat-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-top: 5px;
  }

  /* ── Footer ── */
  .footer {
    text-align: center;
    padding-top: 24px;
    border-top: 1px solid rgba(109,200,130,0.1);
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .footer span { color: var(--g8); }
</style>
</head>
<body>
<div class="page">

  <!-- Header -->
  <div class="header">
    <div class="logo">
      <div class="logo-icon">🌿</div>
      <div class="logo-text">pr<span>ox</span></div>
    </div>
    <div class="header-badges">
      <div class="badge badge-online">online</div>
      <div class="badge badge-version">v2.1</div>
    </div>
  </div>

  <!-- Main Proxy Card -->
  <div class="proxy-card">
    <!-- Tab bar -->
    <div class="proxy-tabbar" id="proxyTabBar">
      <div class="proxy-tab proxy-tab-active" data-tab="0" onclick="switchTab(0)">
        <span class="proxy-tab-favicon">🔒</span>
        <span>New Tab</span>
        <span class="proxy-tab-close" onclick="closeTab(event,0)">✕</span>
      </div>
      <div class="proxy-tab-new" onclick="addTab()" title="New tab">+</div>
    </div>
    <!-- URL bar row -->
    <div class="proxy-urlbar-row">
      <div class="proxy-nav-btn" onclick="navBack()" title="Back">←</div>
      <div class="proxy-nav-btn" onclick="navForward()" title="Forward">→</div>
      <div class="proxy-nav-btn" onclick="reloadTab()" title="Reload" style="font-size:14px;">↻</div>
      <div class="proxy-url-bar" id="activeUrlBar">https://prox.school.internal/gate</div>
    </div>
    <div class="proxy-content">
      <span class="proxy-big-icon">🔒</span>
      <div class="proxy-title">Enter a URL to proxy</div>
      <!-- Disclaimer -->
      <div style="
        background:rgba(255,180,0,0.08);
        border:1px solid rgba(255,180,0,0.25);
        border-radius:12px;
        padding:10px 16px;
        margin-bottom:16px;
        font-size:12px;
        font-weight:700;
        color:rgba(255,200,80,0.9);
        text-align:left;
        line-height:1.5;
      ">⚠️ DISCLAIMER — Close out of anything the proxy opens that is a new tab.</div>
      <div class="proxy-sub">All traffic is routed securely.</div>
      <div class="proxy-input-row">
        <input class="proxy-input" type="text" placeholder="https://example.com" id="proxyUrl" />
        <button class="proxy-go" onclick="goProxy()">Go →</button>
      </div>
    </div>
  </div>

  <!-- Search -->
  <div class="search-wrap">
    <div class="search-icon">🔍</div>
    <input class="search-input" type="text" placeholder="Search the web..." id="searchInput" onkeydown="if(event.key==='Enter') doSearch()" />
    <button class="search-btn" onclick="doSearch()">Search</button>
  </div>


  <!-- Stats -->
  <div class="section-title">Network</div>
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num" id="requests">2,847</div>
      <div class="stat-label">Requests</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="ping">14ms</div>
      <div class="stat-label">Ping</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="users">38</div>
      <div class="stat-label">Online</div>
    </div>
  </div>

  <!-- Apps -->
  <div class="section-title">Apps &amp; Tools</div>
  <div class="app-grid">
    <a class="app-card" href="#" onclick="openViaProxy(event,'https://plai.chat')">
      <div class="app-icon ic-lime">🤖</div>
      <div class="app-name">AI Chat</div>
      <div class="app-tag">no login</div>
    </a>
    <a class="app-card" href="#" onclick="openViaProxy(event,'https://cineby.app')">
      <div class="app-icon ic-warn">🎬</div>
      <div class="app-name">Movies</div>
      <div class="app-tag">cineby</div>
    </a>
    <a class="app-card" href="#" onclick="openViaProxy(event,'https://open.spotify.com')">
      <div class="app-icon ic-green">🎵</div>
      <div class="app-name">Music</div>
      <div class="app-tag">Spotify</div>
    </a>
    <a class="app-card" href="#" onclick="openHacker(event)" id="hacking-card">
      <div class="app-icon ic-lime">💻</div>
      <div class="app-name">Hacking</div>
      <div class="app-tag">inject code</div>
    </a>
    <a class="app-card" href="#" onclick="openSettings(event)">
      <div class="app-icon ic-lime">⚙️</div>
      <div class="app-name">Settings</div>
      <div class="app-tag">Config</div>
    </a>
  </div>

  <!-- VCSA Widget -->
  <div class="section-title" style="margin-top:36px;">Fresh Links</div>
  <div id="vcsa-box" style="
    background: var(--card);
    border: 1px solid var(--card-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    backdrop-filter: blur(10px);
    margin-bottom: 28px;
    transition: border-color 0.3s;
  ">
    <!-- top bar -->
    <div style="
      display: flex; align-items: center; justify-content: space-between;
      padding: 13px 18px;
      border-bottom: 1px solid rgba(109,200,130,0.12);
      background: rgba(0,0,0,0.18);
    ">
      <div style="display:flex; align-items:center; gap:9px;">
        <span style="font-size:16px;">📡</span>
        <span style="font-size:13px; font-weight:800; color:var(--g8); letter-spacing:0.2px;">Hey, here are some proxy links from VCSA</span>
      </div>
      <div style="display:flex; align-items:center; gap:8px;">
        <span id="vcsa-timer-badge" style="
          font-family:'Space Mono',monospace; font-size:11px; color:var(--text-dim);
          background:rgba(0,0,0,0.25); padding:3px 10px; border-radius:99px;
          border:1px solid rgba(109,200,130,0.15);
        ">↻ 30s</span>
        <a href="https://vcsa-yt.blogspot.com" target="_blank" style="
          font-size:11px; font-weight:700; color:var(--text-dim);
          text-decoration:none; padding:3px 10px;
          border-radius:99px; border:1px solid rgba(109,200,130,0.15);
          background:rgba(0,0,0,0.2); transition:color 0.15s;
        " onmouseover="this.style.color='var(--g8)'" onmouseout="this.style.color='var(--text-dim)'">vcsa blog ↗</a>
      </div>
    </div>

    <!-- date stamp -->
    <div id="vcsa-date" style="padding:10px 18px 0; font-size:11px; font-weight:700; letter-spacing:0.8px; text-transform:uppercase; color:var(--text-dim);"></div>

    <!-- link categories -->
    <div id="vcsa-links" style="padding:12px 18px 18px; display:flex; flex-direction:column; gap:14px;"></div>

    <!-- progress bar -->
    <div style="height:2px; background:rgba(109,200,130,0.1);">
      <div id="vcsa-progress" style="height:100%; background:linear-gradient(90deg,var(--g5),var(--g7)); width:100%; transition:width 1s linear;"></div>
    </div>
  </div>

  <!-- Hacker Panel -->
  <div id="hacker-overlay" onclick="closeHacker(event)" style="
    display:none; position:fixed; inset:0; z-index:100;
    background:rgba(0,0,0,0.7); backdrop-filter:blur(4px);
    align-items:center; justify-content:center; padding:20px;
  ">
    <div id="hacker-panel" onclick="event.stopPropagation()" style="
      background:#0a1a0e;
      border:1px solid rgba(109,200,130,0.25);
      border-radius:var(--radius-lg);
      width:100%; max-width:780px;
      max-height:90vh;
      display:flex; flex-direction:column;
      transform:scale(0.93) translateY(20px);
      opacity:0;
      transition:transform 0.25s cubic-bezier(0.34,1.4,0.64,1), opacity 0.2s;
      overflow:hidden;
    ">
      <!-- topbar -->
      <div style="
        display:flex; align-items:center; justify-content:space-between;
        padding:13px 18px;
        border-bottom:1px solid rgba(109,200,130,0.12);
        background:rgba(0,0,0,0.3);
        flex-shrink:0;
      ">
        <div style="display:flex;align-items:center;gap:9px;">
          <span style="font-size:15px;">💻</span>
          <span style="font-size:13px;font-weight:800;color:var(--g8);">HTML Injector</span>
          <span style="font-size:10px;font-weight:700;color:var(--text-dim);background:rgba(74,170,99,0.12);padding:2px 8px;border-radius:99px;border:1px solid rgba(74,170,99,0.2);">hacking mode</span>
        </div>
        <div style="display:flex;gap:8px;">
          <button onclick="runHtml()" style="
            background:linear-gradient(135deg,var(--g4),var(--g6));
            color:#c2edc6; border:none; border-radius:10px;
            padding:7px 16px; font-family:'Nunito',sans-serif;
            font-size:12px; font-weight:800; cursor:pointer;
          ">▶ Run</button>
          <button onclick="closeHacker()" style="
            background:rgba(255,255,255,0.06); color:var(--text-dim);
            border:1px solid rgba(109,200,130,0.15); border-radius:10px;
            padding:7px 12px; font-family:'Nunito',sans-serif;
            font-size:12px; font-weight:800; cursor:pointer;
          ">✕</button>
        </div>
      </div>

      <!-- split view -->
      <div style="display:flex;flex:1;min-height:0;overflow:hidden;">
        <!-- editor side -->
        <div style="flex:1;display:flex;flex-direction:column;border-right:1px solid rgba(109,200,130,0.1);">
          <div style="padding:8px 14px;font-size:10px;font-weight:800;letter-spacing:0.8px;text-transform:uppercase;color:var(--text-dim);background:rgba(0,0,0,0.2);border-bottom:1px solid rgba(109,200,130,0.08);">Editor</div>
          <textarea id="html-input" spellcheck="false" style="
            flex:1; background:transparent; border:none; outline:none; resize:none;
            font-family:'Space Mono',monospace; font-size:12px; line-height:1.6;
            color:var(--g9); padding:14px; min-height:320px;
            caret-color:var(--g7);
          " placeholder="<!-- paste your HTML here -->&#10;<h1>Hello world</h1>&#10;<p>You're hacking now 😎</p>"></textarea>
        </div>
        <!-- preview side -->
        <div style="flex:1;display:flex;flex-direction:column;">
          <div style="padding:8px 14px;font-size:10px;font-weight:800;letter-spacing:0.8px;text-transform:uppercase;color:var(--text-dim);background:rgba(0,0,0,0.2);border-bottom:1px solid rgba(109,200,130,0.08);">Preview</div>
          <iframe id="html-preview" sandbox="allow-scripts" style="
            flex:1; border:none; background:white; min-height:320px;
          "></iframe>
        </div>
      </div>

      <!-- status bar -->
      <div style="
        padding:7px 16px;
        font-family:'Space Mono',monospace; font-size:10px; color:var(--text-dim);
        background:rgba(0,0,0,0.25); border-top:1px solid rgba(109,200,130,0.08);
        display:flex; align-items:center; gap:8px; flex-shrink:0;
      ">
        <span id="hacker-status">ready</span>
        <span style="margin-left:auto;color:rgba(109,200,130,0.3);">click ▶ Run or Ctrl+Enter to execute</span>
      </div>
    </div>
  </div>

  <!-- Settings Panel -->
  <div id="settings-overlay" onclick="closeSettings(event)" style="
    display:none; position:fixed; inset:0; z-index:100;
    background:rgba(0,0,0,0.55); backdrop-filter:blur(4px);
    align-items:flex-end; justify-content:center;
  ">
    <div id="settings-panel" onclick="event.stopPropagation()" style="
      background:#0f2614;
      border:1px solid rgba(109,200,130,0.2);
      border-radius:28px 28px 0 0;
      padding:24px 24px 40px;
      width:100%; max-width:780px;
      transform:translateY(100%);
      transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
    ">
      <!-- handle -->
      <div style="width:40px;height:4px;border-radius:99px;background:rgba(109,200,130,0.3);margin:0 auto 20px;"></div>

      <div style="font-size:17px;font-weight:900;color:var(--text);margin-bottom:4px;">Settings</div>
      <div style="font-size:12px;color:var(--text-dim);margin-bottom:22px;font-weight:600;">Personalize Prox. Saved automatically.</div>

      <!-- Theme label -->
      <div style="font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);margin-bottom:12px;">Color Theme</div>

      <!-- Swatches -->
      <div id="theme-swatches" style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:28px;"></div>

      <!-- Custom hue slider -->
      <div style="font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase;color:var(--text-dim);margin-bottom:10px;">Custom Hue</div>
      <div style="display:flex;align-items:center;gap:14px;">
        <input type="range" id="hue-slider" min="0" max="359" value="130" style="flex:1;" oninput="applyHue(this.value)">
        <div id="hue-preview" style="width:32px;height:32px;border-radius:10px;border:1px solid rgba(255,255,255,0.15);flex-shrink:0;"></div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="footer" style="margin-top: 40px;">
    <span>Prox</span> by GTP · School edition · Use responsibly 🌿
  </div>

</div>

<script>
  function doSearch() {
    const q = document.getElementById('searchInput').value.trim();
    if (q) window.open('https://www.google.com/search?q=' + encodeURIComponent(q), '_blank');
  }

  const PROXY_BASE = 'https://storied-snickerdoodle-cb565f.netlify.app/';

  function goProxy() {
    let url = document.getElementById('proxyUrl').value.trim();
    if (!url) return;
    if (!url.startsWith('http')) url = 'https://' + url;
    const proxied = PROXY_BASE + encodeURIComponent(url);
    try {
      const host = new URL(url).hostname;
      tabs[activeTab].url = url;
      tabs[activeTab].title = host;
      renderTabs();
    } catch(e) {}
    window.open(proxied, '_blank');
  }
  let req = 2847;
  setInterval(() => {
    req += Math.floor(Math.random() * 4);
    document.getElementById('requests').textContent = req.toLocaleString();
  }, 2200);

  // Fluctuate ping
  setInterval(() => {
    const p = 10 + Math.floor(Math.random() * 20);
    document.getElementById('ping').textContent = p + 'ms';
  }, 1800);

  // Fluctuate users
  let u = 38;
  setInterval(() => {
    u += (Math.random() > 0.5 ? 1 : -1);
    u = Math.max(30, Math.min(50, u));
    document.getElementById('users').textContent = u;
  }, 3500);

  // ── Tab system ──
  const tabFavicons = ['🔒','🌿','🎮','🤖','💬','🔍','🎬','🎵'];
  let tabs = [{ title: 'New Tab', url: 'https://prox.school.internal/gate', favicon: '🔒' }];
  let activeTab = 0;

  function renderTabs() {
    const bar = document.getElementById('proxyTabBar');
    bar.innerHTML = '';
    tabs.forEach((t, i) => {
      const el = document.createElement('div');
      el.className = 'proxy-tab' + (i === activeTab ? ' proxy-tab-active' : '');
      el.setAttribute('data-tab', i);
      el.innerHTML = `<span class="proxy-tab-favicon">${t.favicon}</span><span style="max-width:90px;overflow:hidden;text-overflow:ellipsis">${t.title}</span><span class="proxy-tab-close" onclick="closeTab(event,${i})">✕</span>`;
      el.onclick = (e) => { if (!e.target.classList.contains('proxy-tab-close')) switchTab(i); };
      bar.appendChild(el);
    });
    const plus = document.createElement('div');
    plus.className = 'proxy-tab-new';
    plus.title = 'New tab';
    plus.textContent = '+';
    plus.onclick = addTab;
    bar.appendChild(plus);
    document.getElementById('activeUrlBar').textContent = tabs[activeTab].url;
  }

  function switchTab(i) {
    activeTab = i;
    renderTabs();
  }

  function addTab() {
    const fi = tabFavicons[Math.floor(Math.random() * tabFavicons.length)];
    tabs.push({ title: 'New Tab', url: 'https://prox.school.internal/gate', favicon: fi });
    activeTab = tabs.length - 1;
    renderTabs();
  }

  function closeTab(e, i) {
    e.stopPropagation();
    if (tabs.length === 1) { tabs[0] = { title: 'New Tab', url: 'https://prox.school.internal/gate', favicon: '🔒' }; activeTab = 0; renderTabs(); return; }
    tabs.splice(i, 1);
    if (activeTab >= tabs.length) activeTab = tabs.length - 1;
    renderTabs();
  }

  function navBack() {}
  function navForward() {}
  function reloadTab() {
    const bar = document.getElementById('activeUrlBar');
    bar.textContent = '↻ reloading...';
    setTimeout(() => { bar.textContent = tabs[activeTab].url; }, 600);
  }

  function openViaProxy(e, url) {
    e.preventDefault();
    window.open(PROXY_BASE + encodeURIComponent(url), '_blank');
  }

  renderTabs();

  const vcsaData = [
    {
      date: '10-02-2026',
      categories: [
        { name: '🐸 Frogies Arcade', links: ['https://highschoolmathteachers.com/'] },
        { name: '🔴 Reds Exploit Corner', links: ['https://rec-playernation.maiswebsites.com/', 'https://welovevcsa.thevictoryseed.org/', 'https://vcsa-yt.my-ns.com/'] },
        { name: '😴 Boredom', links: ['https://vcsa.thevictoryseed.org/', 'https://boringvcsa.maiswebsites.com/', 'https://bored.ynbbs.cc/'] },
        { name: '🚀 Space', links: ['https://playernation.maiswebsites.com/', 'https://vcsainspace.thevictoryseed.org/'] },
        { name: '💭 DaydreamX', links: ['https://dreamingvcsa.maiswebsites.com/', 'https://planting.vseesa.thevictoryseed.org/'] },
        { name: '🚌 Shuttle', links: ['https://classroomlearning.maxmirgidro.ru/', 'https://wikipedialist.wikidelia.net/'] },
        { name: '🍄 Truffled', links: ['https://windows.wincheapguesthouse.com/', 'https://coolmathgames.metropolitanstaffingsolutions.com/'] },
        { name: '☁️ Nebulo', links: ['https://chemistry.axiomait.pro/', 'https://historyabc.markscully.com/', 'https://worldwar.pal-wars.com/', 'https://midterms.wrexham.cn/'] },
        { name: '🧥 Over-Cloaked', links: ['https://basicalgebra.gatewaysuppliers.com.np/', 'https://funlearning.gatewaysuppliers.com.np/', 'https://oz96krcc.beanweb.qzz.io.cdn.cloudflare.net/'] },
        { name: '🌌 Galaxy', links: ['https://plant-biography.thevictoryseed.org/', 'https://victory.thevictoryseed.org/', 'https://victory.seed.thevictoryseed.org/', 'https://host-site.maiswebsites.com/', 'https://idfk.deez.nz/', 'https://ibribeillegals.vaultnoir.com/'] }
      ]
    },
    {
      date: '03-09-2026',
      categories: [
        { name: '🌐 16 Apps', links: ['https://vcsa-yt.blogspot.com/2026/02/72-new.html'] }
      ]
    },
    {
      date: '02-26-2026',
      categories: [
        { name: '👀 Fresh Links', links: ['https://xubty.isabaka.srijanakhadka.com.np/', 'http://powerschool-login.com.stressmap.ru/', 'https://lightsped-filter.tcloud.my/'] }
      ]
    }
  ];

  let vcsaIdx = 0;
  let vcsaCountdown = 30;
  const ROTATE_SEC = 30;

  function renderVCSA() {
    const set = vcsaData[vcsaIdx];
    document.getElementById('vcsa-date').textContent = 'Posted ' + set.date;
    const container = document.getElementById('vcsa-links');
    container.innerHTML = '';
    set.categories.forEach(cat => {
      const row = document.createElement('div');
      row.innerHTML = `
        <div style="font-size:12px;font-weight:800;color:var(--text-muted);margin-bottom:7px;letter-spacing:0.2px;">${cat.name}</div>
        <div style="display:flex;flex-wrap:wrap;gap:7px;">
          ${cat.links.map(l => `
            <a href="${l}" target="_blank" style="
              display:inline-block;
              background:rgba(0,0,0,0.22);
              border:1px solid rgba(109,200,130,0.2);
              border-radius:10px;
              padding:6px 13px;
              font-family:'Space Mono',monospace;
              font-size:11px;
              color:var(--g9);
              text-decoration:none;
              transition:all 0.15s;
              word-break:break-all;
            "
            onmouseover="this.style.background='rgba(74,170,99,0.18)';this.style.borderColor='rgba(109,200,130,0.45)';this.style.color='var(--gb)'"
            onmouseout="this.style.background='rgba(0,0,0,0.22)';this.style.borderColor='rgba(109,200,130,0.2)';this.style.color='var(--g9)'"
            >${new URL(l.startsWith('http')?l:'https://'+l).hostname}</a>
          `).join('')}
        </div>`;
      container.appendChild(row);
    });

    // reset progress bar
    const prog = document.getElementById('vcsa-progress');
    prog.style.transition = 'none';
    prog.style.width = '100%';
    setTimeout(() => {
      prog.style.transition = `width ${ROTATE_SEC}s linear`;
      prog.style.width = '0%';
    }, 50);
  }

  function tickVCSA() {
    vcsaCountdown--;
    document.getElementById('vcsa-timer-badge').textContent = '↻ ' + vcsaCountdown + 's';
    if (vcsaCountdown <= 0) {
      vcsaIdx = (vcsaIdx + 1) % vcsaData.length;
      vcsaCountdown = ROTATE_SEC;
      const box = document.getElementById('vcsa-box');
      box.style.borderColor = 'rgba(109,200,130,0.55)';
      setTimeout(() => box.style.borderColor = '', 600);
      renderVCSA();
    }
  }

  // ── HTML Hacker Panel ──
  function openHacker(e) {
    if (e) e.preventDefault();
    const overlay = document.getElementById('hacker-overlay');
    const panel = document.getElementById('hacker-panel');
    overlay.style.display = 'flex';
    requestAnimationFrame(() => {
      panel.style.transform = 'scale(1) translateY(0)';
      panel.style.opacity = '1';
    });
  }

  function closeHacker(e) {
    if (e && e.target !== document.getElementById('hacker-overlay')) return;
    const panel = document.getElementById('hacker-panel');
    panel.style.transform = 'scale(0.93) translateY(20px)';
    panel.style.opacity = '0';
    setTimeout(() => { document.getElementById('hacker-overlay').style.display = 'none'; }, 220);
  }

  function runHtml() {
    const code = document.getElementById('html-input').value;
    const iframe = document.getElementById('html-preview');
    const status = document.getElementById('hacker-status');
    const lines = code.split('\n').length;
    iframe.srcdoc = code;
    status.textContent = `injected ${lines} line${lines !== 1 ? 's' : ''} ✓`;
    status.style.color = 'var(--g8)';
    setTimeout(() => { status.textContent = 'ready'; status.style.color = ''; }, 2500);
  }

  // Ctrl+Enter to run
  document.addEventListener('keydown', e => {
    if (e.ctrlKey && e.key === 'Enter' && document.getElementById('hacker-overlay').style.display === 'flex') {
      runHtml();
    }
    if (e.key === 'Escape') {
      closeHacker({ target: document.getElementById('hacker-overlay') });
      closeSettings({ target: document.getElementById('settings-overlay') });
    }
  });

  // ── Settings & Theme System ──
  const themes = [
    { name: 'Forest',  hue: 130 },
    { name: 'Ocean',   hue: 210 },
    { name: 'Sunset',  hue: 20  },
    { name: 'Violet',  hue: 270 },
    { name: 'Rose',    hue: 340 },
    { name: 'Gold',    hue: 45  },
    { name: 'Cyan',    hue: 185 },
    { name: 'Slate',   hue: 220 },
  ];

  function hueToRamp(h) {
    return {
      g0: `hsl(${h},45%,7%)`,
      g1: `hsl(${h},48%,11%)`,
      g2: `hsl(${h},50%,15%)`,
      g3: `hsl(${h},52%,20%)`,
      g4: `hsl(${h},54%,26%)`,
      g5: `hsl(${h},55%,32%)`,
      g6: `hsl(${h},56%,40%)`,
      g7: `hsl(${h},55%,48%)`,
      g8: `hsl(${h},52%,60%)`,
      g9: `hsl(${h},48%,72%)`,
      ga: `hsl(${h},45%,84%)`,
      gb: `hsl(${h},42%,93%)`,
      cardBorder: `hsla(${h},55%,55%,0.18)`,
      textMuted:  `hsl(${h},48%,72%)`,
      textDim:    `hsl(${h},50%,44%)`,
      text:       `hsl(${h},42%,93%)`,
    };
  }

  function applyHue(h) {
    h = parseInt(h);
    const r = hueToRamp(h);
    const root = document.documentElement.style;
    root.setProperty('--g0', r.g0);
    root.setProperty('--g1', r.g1);
    root.setProperty('--g2', r.g2);
    root.setProperty('--g3', r.g3);
    root.setProperty('--g4', r.g4);
    root.setProperty('--g5', r.g5);
    root.setProperty('--g6', r.g6);
    root.setProperty('--g7', r.g7);
    root.setProperty('--g8', r.g8);
    root.setProperty('--g9', r.g9);
    root.setProperty('--ga', r.ga);
    root.setProperty('--gb', r.gb);
    root.setProperty('--card-border', r.cardBorder);
    root.setProperty('--text', r.text);
    root.setProperty('--text-muted', r.textMuted);
    root.setProperty('--text-dim', r.textDim);
    document.getElementById('settings-panel').style.background = r.g1;
    // update body bg blobs
    document.body.style.setProperty('--blob-color', `hsla(${h},55%,35%,0.35)`);
    // update hue preview
    const prev = document.getElementById('hue-preview');
    if (prev) prev.style.background = `hsl(${h},55%,48%)`;
    // update slider value
    const sl = document.getElementById('hue-slider');
    if (sl) sl.value = h;
    // mark active swatch
    document.querySelectorAll('.theme-swatch').forEach(s => {
      s.style.outline = parseInt(s.dataset.hue) === h ? '2px solid white' : 'none';
      s.style.outlineOffset = '2px';
    });
    localStorage.setItem('prox-hue', h);
  }

  function buildSwatches() {
    const wrap = document.getElementById('theme-swatches');
    themes.forEach(t => {
      const btn = document.createElement('div');
      btn.className = 'theme-swatch';
      btn.dataset.hue = t.hue;
      btn.title = t.name;
      btn.style.cssText = `
        width:44px; height:44px; border-radius:14px; cursor:pointer;
        background:hsl(${t.hue},55%,40%);
        border:1px solid hsla(${t.hue},55%,60%,0.35);
        display:flex; align-items:center; justify-content:center;
        font-size:11px; font-weight:800; color:hsl(${t.hue},40%,88%);
        flex-direction:column; gap:2px; transition:transform 0.12s;
        flex-shrink:0;
      `;
      btn.innerHTML = `<span style="font-size:9px;letter-spacing:0.3px;text-transform:uppercase">${t.name}</span>`;
      btn.onmouseover = () => btn.style.transform = 'scale(1.08)';
      btn.onmouseout  = () => btn.style.transform = 'scale(1)';
      btn.onclick = () => applyHue(t.hue);
      wrap.appendChild(btn);
    });
  }

  function openSettings(e) {
    e.preventDefault();
    const overlay = document.getElementById('settings-overlay');
    const panel   = document.getElementById('settings-panel');
    overlay.style.display = 'flex';
    requestAnimationFrame(() => { panel.style.transform = 'translateY(0)'; });
  }

  function closeSettings(e) {
    const panel = document.getElementById('settings-panel');
    panel.style.transform = 'translateY(100%)';
    setTimeout(() => { document.getElementById('settings-overlay').style.display = 'none'; }, 300);
  }

  // Init
  buildSwatches();
  const savedHue = localStorage.getItem('prox-hue');
  applyHue(savedHue !== null ? savedHue : 130);

  renderVCSA();
  setInterval(tickVCSA, 1000);
</script>
</body>
</html>
